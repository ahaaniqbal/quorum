# ── Frontend (Vite) — must be VITE_ prefixed, safe-to-expose only ──
VITE_CONVEX_URL=            # printed by `npx convex dev`
VITE_VAPI_PUBLIC_KEY=       # Vapi public/web key (browser SDK)
VITE_VAPI_ASSISTANT_ID=     # optional: prebuilt assistant id

# ── Convex server env (set with: npx convex env set KEY value) ──
# These are NOT read by the frontend. Run the npx convex env set commands.
# OPENAI_API_KEY=
# FIBER_API_KEY=
# VAPI_API_KEY=
# DEEPGRAM_API_KEY=
# SMALLEST_API_KEY=
# COMPOSIO_API_KEY=
# AGENTMAIL_API_KEY=
# HYDRADB_API_KEY=
# FIRECRAWL_API_KEY=
